# ─── Data ────────────────────────────────────────────────────────────────────
# Kaggle credentials for dataset download
# Get from: https://www.kaggle.com/settings → API → Create New Token
KAGGLE_USERNAME=your_kaggle_username_here
KAGGLE_KEY=your_kaggle_key_here

# Path where datasets will be stored
DATA_DIR=./data/raw

# ─── Model Config ─────────────────────────────────────────────────────────────
# Decision threshold for fraud classification (default 0.5)
# Lower = more sensitive (more FP), higher = more conservative (more FN)
FRAUD_THRESHOLD=0.5

# XGBoost/LightGBM model weight vs GNN in score fusion (0.0–1.0)
# 0.6 means 60% tabular, 40% GNN
TABULAR_MODEL_WEIGHT=0.6

# ─── MLflow ──────────────────────────────────────────────────────────────────
# MLflow tracking URI — uses local file store by default
MLFLOW_TRACKING_URI=sqlite:///mlflow.db

# ─── API ─────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8001

# ─── Drift Monitoring ────────────────────────────────────────────────────────
# Number of transactions in the rolling window for drift detection
DRIFT_WINDOW_SIZE=1000

# Drift score threshold to trigger retraining (0.0–1.0)
DRIFT_THRESHOLD=0.15

# ─── Streaming Simulator ─────────────────────────────────────────────────────
# Transactions per second for the simulator
SIMULATOR_TPS=10
